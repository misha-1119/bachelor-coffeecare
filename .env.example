TELEGRAM_BOT_TOKEN=your_token_here
CONVEX_URL=https://your-deployment.convex.cloud

# Qdrant Cloud (get from qdrant.io dashboard — ask project owner for credentials)
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# LLM (Ollama + lapa, managed by docker-compose)
LLAMA_MODEL=hf.co/lapa-llm/lapa-v0.1.2-instruct-GGUF

DEBUG_MODE=0
CHUNK_THRESHOLD=0.45
